# Copy to .env.local and fill in. Never commit real values.

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # publishable / anon key (safe for the browser)
SUPABASE_SERVICE_ROLE_KEY=              # secret — server only (onboarding provisions weddings)

# --- Anthropic (AI document extraction) ---
ANTHROPIC_API_KEY=                      # secret — server only

# --- Resend (sending invitation emails) — optional ---
# Leave blank to disable one-click sending (Copy links / Export CSV still work).
# Needs a verified domain in Resend before it can reach guests.
RESEND_API_KEY=
INVITE_FROM_EMAIL="Your Names <rsvp@yourdomain.com>"
